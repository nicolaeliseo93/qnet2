VITE_APP_NAME="Starter [ DEV ]"
VITE_APP_NAME_SIDEBAR="-Starter [ DEV ]"
VITE_APP_DESCRIPTION="Starter description"
VITE_API_URL=http://backend.test/
VITE_API_VERSION="api"
VITE_IS_PRODUCTION=false

# AG Grid Enterprise license key. Required at runtime to remove the license
# watermark and unlock enterprise features (Server-Side Row Model). Never commit
# a real key — set it per-environment only.
VITE_AG_GRID_LICENSE_KEY=""

# Polling interval (ms) for the unread notifications count. Defaults to 30000.
VITE_NOTIFICATIONS_POLL_INTERVAL=30000
